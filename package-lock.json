{
  "name": "openhfp-workspace",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "openhfp-workspace",
      "version": "0.0.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "devDependencies": {
        "typescript": "^5.7.2"
      }
    },
    "node_modules/@openhfp/devtools": {
      "resolved": "packages/devtools",
      "link": true
    },
    "node_modules/@openhfp/types": {
      "resolved": "packages/types",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/devtools": {
      "name": "@openhfp/devtools",
      "version": "0.0.0",
      "license": "MIT",
      "dependencies": {
        "@openhfp/types": "0.0.0"
      }
    },
    "packages/types": {
      "name": "@openhfp/types",
      "version": "0.0.0",
      "license": "MIT"
    }
  }
}
